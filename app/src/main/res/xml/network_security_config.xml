<?xml version="1.0" encoding="utf-8"?>
<!--
    SECURITY FIX: Network Security Configuration
    - Cleartext (HTTP) traffic completely blocked
    - Only HTTPS allowed for all domains
    - Prevents MITM attacks and accidental HTTP leaks
    OWASP MASVS: MSTG-NETWORK-2, MSTG-NETWORK-3
-->
<network-security-config>
    <!-- Block ALL cleartext traffic globally -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Only trust system CAs — no user-installed certs -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- HuggingFace domains — HTTPS only -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">huggingface.co</domain>
        <domain includeSubdomains="true">router.huggingface.co</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
